 *
 * Waveshare ESP32-S3-ETH: ESP32-S3-WROOM-1U-N16R8 (16MB flash, 8MB PSRAM)
 * with an onboard WIZnet W5500 10/100 Ethernet controller on SPI2.
 */
/dts-v1/;

#include <espressif/esp32s3/esp32s3_wroom_n16r8.dtsi>
#include <espressif/partitions_0x0_amp_16M.dtsi>
#include <zephyr/dt-bindings/gpio/gpio.h>
#include "waveshare_esp32_s3_eth-pinctrl.dtsi"

/ {
	model = "Waveshare ESP32-S3-ETH PROCPU";
	compatible = "espressif,esp32s3";

	aliases {
		watchdog0 = &wdt0;
	};

	chosen {
		zephyr,sram = &sram1;
		/* USB-C is the ESP32-S3 native USB-Serial/JTAG; UART0 (GPIO43/44)
		 * is not broken out to the port, so the console lives on USB. */
		zephyr,console = &usb_serial;
		zephyr,shell-uart = &usb_serial;
		zephyr,flash = &flash0;
		zephyr,code-partition = &slot0_partition;
		zephyr,bt-hci = &esp32_bt_hci;
	};
};

&usb_serial {
	status = "okay";
};

&gpio0 {
	status = "okay";
};

&gpio1 {
	status = "okay";
};

&spi2 {
	#address-cells = <1>;
	#size-cells = <0>;
	status = "okay";
	pinctrl-0 = <&spim2_w5500>;
	pinctrl-names = "default";
	cs-gpios = <&gpio0 14 GPIO_ACTIVE_LOW>;

	ethernet: w5500@0 {
		compatible = "wiznet,w5500";
		reg = <0x0>;
		spi-max-frequency = <40000000>;
		int-gpios = <&gpio0 10 GPIO_ACTIVE_LOW>;
		reset-gpios = <&gpio0 9 GPIO_ACTIVE_LOW>;
		/* W5500 has no MAC EEPROM; assign a locally-administered address. */
		local-mac-address = [02 00 00 00 02 03];
		status = "okay";
	};
};

&wdt0 {
	status = "okay";
};

&trng0 {
	status = "okay";
};

&esp32_bt_hci {
	status = "okay";
};

&wifi {
	status = "okay";
};

zephyr_udc0: &usb_otg {
	status = "okay";
};
