&i2c0 {
	status = "okay";

	seesaw: seesaw@30 {
		compatible = "adafruit,seesaw";
		reg = <0x30>;
		status = "okay";
	};

	mfd_seesaw: seesaw@49 {
		compatible = "adafruit,seesaw-mfd";
		reg = <0x49>;
		read-delay-us = <0>;
		status = "okay";

		gpio_child: gpio {
			compatible = "adafruit,seesaw-gpio";
			gpio-controller;
			#gpio-cells = <2>;
			ngpios = <16>;
		};

		adc_child: adc {
			compatible = "adafruit,seesaw-adc";
			#io-channel-cells = <1>;
		};
	};
};
